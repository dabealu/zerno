{
    "spacing": 4, // Size of gaps in between of the different modules

    "layer": "bottom", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 22, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width

    // Choose the order of the modules
    "modules-left": [
        "sway/workspaces",
        "sway/mode"
    ],
    // "modules-center": ["sway/window"],
    "modules-right": [
        "mpris",
        "pulseaudio",
        "cpu",
        "memory",
        "disk",
        "network",
        "battery",
        "clock",
        "sway/language",
        "tray"
    ],
    // Modules configuration
    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },
    "tray": {
        "icon-size": 24,
        "spacing": 8
    },
    "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%b %d.%m.%Y %a %H:%M:%S}",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months":   "<span color='#ffead3'><b>{}</b></span>",
                "days":     "<span color='#ffffff'>{}</span>",
                "weeks":    "<span color='#99ffdd'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}></b></span>",
                "today":    "<span color='#00ff00'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": "<span font-size='16pt' rise='-2000'>َ°ک·</span> {usage}%",
        "tooltip": true,
        "states": {
            "critical": 95
        }
    },
    "memory": {
        "format": "<span font-size='16pt' rise='-2000'>î‰¦</span> {}%",
        "states": {
            "critical": 95
        }
    },
    "disk": {
        "interval": 30,
        "format": "<span font-size='16pt' rise='-2000'>ï‡€</span> {percentage_used}%",
        "path": "/",
        "states": {
            "warning": 85,
            "critical": 95
        }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "<span font-size='16pt' rise='-2000'>{icon}</span> {capacity}%",
        "format-charging": "<span font-size='16pt' rise='-2000'>ïƒ§</span> {capacity}%",
        "format-plugged": "<span font-size='16pt' rise='-2000'>ïƒ§</span> {capacity}%",
        "format-alt": "bat: {time}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["َ°پ»", "َ°پ½", "َ°پ؟", "َ°‚پ", "َ°پ¹"]
    },
    "network": {
        "interval": 5,
        "format": "<span font-size='16pt' rise='-2000'>{icon}</span>",
        "format-alt": "â†“{bandwidthDownBytes} â†‘{bandwidthUpBytes}",
        "format-disconnected": "<span font-size='16pt' rise='-2000'>âœ—</span>",
        "format-icons": {
            "ethernet": "ïƒ¬",
            "wifi": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"]
        },
        "tooltip-format": "{ifname}: {ipaddr}",
        "tooltip-format-wifi": "{ifname} ({essid}, {signalStrength}%): {ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}"
    },
    "mpris": {
        "format": "{status_icon} {title}",
        "format-paused": "{status_icon} {title}",
        "format-stopped": "",
        "status-icons": {
            "playing": "ïپ‹",
            "paused": "ïپŒ",
            "stopped": "âڈ¹"
        },
        "title-len": 45,
        "ellipsis": "â€¦",
        "tooltip-format": "{status_icon} {dynamic} [{player}]",
        "dynamic-order": ["title", "artist", "album"],
        "dynamic-separator": ", "
    },
    "pulseaudio": {
        "scroll-step": 1, // %, can be a float
        "format": "<span font-size='16pt' rise='-2000'>َ°•¾</span> {volume}% <span font-size='16pt' rise='-2000'>َ°چ¬</span> {format_source}",
        "format-bluetooth": "<span font-size='16pt' rise='-2000'>َ°•¾</span> {volume}% <span font-size='16pt' rise='-2000'>َ°چ¬</span> {format_source}",
        "format-bluetooth-muted": "<span font-size='16pt' rise='-2000'>ï€¦</span> {format_source}",
        "format-muted": "<span font-size='16pt' rise='-2000'>ï€¦</span> {format_source}",
        "format-source": "{volume}%",
        "format-source-muted": "<span font-size='16pt' rise='-2000'>ï„±</span>",
        "on-click": "pavucontrol"
    }
}
